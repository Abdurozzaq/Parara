{
  "name": "parara",
  "version": "1.0.0",
  "description": "Advanced Indonesian paraphrasing API with layered local transformations",
  "main": "electron/main.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "generate:synonyms": "node generate-data.js",
    "generate:icon": "node scripts/generate-icon.js",
    "desktop:dev": "electron .",
    "desktop:start": "electron .",
    "desktop:dist": "electron-builder --win nsis"
  },
  "keywords": [],
  "author": "Abdurozzaq Nurul Hadi",
  "license": "ISC",
  "type": "commonjs",
  "jest": {
    "setupFiles": [
      "<rootDir>/tests/jest.setup.js"
    ]
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "compromise": "^14.15.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "pngjs": "^7.0.0",
    "supertest": "^7.2.2",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.parara.desktop",
    "productName": "Parara",
    "icon": "assets/parara.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "assets/**/*",
      "electron/**/*",
      "public/**/*",
      "src/**/*",
      "wordlist.txt",
      ".env",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "icon": "assets/parara.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
