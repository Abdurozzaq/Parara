SYNONYM_WORDLIST=./wordlist.txt
SYNONYM_OUTPUT=./src/data/synonyms.generated.json
SYNONYM_WORD_LIMIT=3000
SYNONYM_MAX_REPLACEMENTS=8
SYNONYM_REQUEST_DELAY_MS=350
SYNONYM_SOURCE_URL=http://www.sinonimkata.com
SYNONYM_REQUIRE_IN_WORDLIST=0
SYNONYM_CPU_TARGET=0.75
SYNONYM_MAX_CONCURRENCY=0

